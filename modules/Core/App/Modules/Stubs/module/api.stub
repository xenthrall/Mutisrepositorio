<?php

use Illuminate\Support\Facades\Route;

// Recuerda que el ModuleServiceProvider ya le inyecta el prefijo "api/{{module_kebab}}" a este archivo.
Route::get('/ping', function () {
    return response()->json([
        'status' => 'success',
        'message' => '🚀 Hola desde la API del módulo: {{module}}'
    ]);
});